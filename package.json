    "prepublishOnly": "bun run typecheck && bun test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "ink": "^5.2.0",
    "ink-text-input": "^6.0.0",
    "openai": "^4.89.1",
    "react": "^18.3.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.14.2",
    "@types/react": "^18.3.28",
    "typescript": "^5.8.3"
  }
}
