{
  "name": "nexus-agent",
  "version": "0.3.0",
  "description": "Nexus Agent — 基于 ReAct 范式的自主编程 CLI Agent",
  "type": "module",
  "private": false,
  "license": "MIT",
  "author": "guozongzhi",
  "repository": {
    "type": "git",
    "url": "https://github.com/guozongzhi/NexusAgent.git"
  },
  "keywords": ["ai", "agent", "cli", "react", "mcp", "coding-assistant", "llm"],
  "bin": {
